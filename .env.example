# LLM 配置（必需）
LLM_MODEL=qwen3.5-27b
LLM_API_KEY=your_dashscope_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2000

# API 配置
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=True

# 搜索 API 配置（必需）
SEARCH_API_BASE_URL=http://localhost:8001

# 博查搜索配置（可选）
# BOCHA_API_KEY=your_bocha_api_key_here
# BOCHA_API_URL=https://api.bochaai.com/v1/web-search
# BOCHA_TIMEOUT=30

# Redis 配置（可选，用于 Level 3 缓存）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=

# 缓存配置
CACHE_TTL=3600
SEMANTIC_CACHE_THRESHOLD=0.85

# 性能配置
MAX_WORKERS=4
TIMEOUT_SECONDS=30
